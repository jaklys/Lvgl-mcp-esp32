{
  "name": "lvgl-mcp-server",
  "version": "1.2.0",
  "description": "MCP server for LVGL headless simulator - visual feedback loop for ESP32 UI development",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lvgl-mcp-server": "bin/lvgl-mcp-server.mjs"
  },
  "files": [
    "dist/",
    "bin/",
    "scripts/postinstall.mjs"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "postinstall": "node scripts/postinstall.mjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jaklys/Lvgl-mcp-esp32"
  },
  "keywords": [
    "mcp",
    "lvgl",
    "esp32",
    "simulator",
    "headless",
    "model-context-protocol"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0"
  }
}
